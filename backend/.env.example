PORT=3001
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL=false
PA_NEW_APPLICATION_FLOW_URL=https://example.com/webhook/new-application
PA_RESUME_ANALYSIS_FLOW_URL=https://example.com/webhook/resume-analysis
WEBHOOK_API_KEY=your-secret-api-key-here
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@jobflow.ai
APP_BASE_URL=http://localhost:5173

# ─── AI Keys ───
OPENROUTER_API_KEY=sk-or-v1-...
TAVILY_API_KEY=tvly-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Groq (fast + free — get key at console.groq.com) ───
# When set, Groq is used as primary LLM. OpenRouter is the fallback.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-70b-versatile

# ─── Cloudinary (Resume Storage — free at cloudinary.com) ───
# Paste the full CLOUDINARY_URL from your Cloudinary dashboard Settings > API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── SendGrid Email Service (free tier: 100 emails/day) ───
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@jobflow.ai
HR_NOTIFICATION_EMAIL=hr@yourcompany.com

# ─── Razorpay Billing (use test keys for development) ───
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_test_secret_here
