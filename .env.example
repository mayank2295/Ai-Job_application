# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# Power Automate Workflow URLs
# Get these from Power Automate after creating your flows
PA_NEW_APPLICATION_FLOW_URL=https://prod-xx.westus.logic.azure.com:443/workflows/...
PA_RESUME_ANALYSIS_FLOW_URL=https://prod-xx.westus.logic.azure.com:443/workflows/...

# Webhook Security
WEBHOOK_API_KEY=your-secret-api-key-here

# AI (Gemini)
# Choose which provider to try first: `xai` or `gemini`.
# Default is `gemini`.
AI_PRIMARY_PROVIDER=gemini
AI_MAX_HISTORY=10
AI_MAX_CHARS_PER_MESSAGE=2000
GEMINI_MODEL=gemini-flash-latest
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_API_KEY=

# AI (xAI Grok fallback)
# If Gemini fails (or GEMINI_API_KEY is missing), backend will try xAI when XAI_API_KEY is set.
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest
XAI_MAX_OUTPUT_TOKENS=512
XAI_API_KEY=

# Database
DB_PATH=./data/applications.db

# Azure Blob Storage (Resume Uploads)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=resumes
AZURE_STORAGE_PUBLIC_READ=false
AZURE_BLOB_URL_EXPIRY_MINUTES=60
AZURE_STORAGE_ACCOUNT_NAME=your-account
AZURE_STORAGE_ACCOUNT_KEY=your-key

# Frontend (Vite) - Firebase Auth/Firestore
# Put these in `frontend/.env.local` (Vite only exposes vars prefixed with VITE_).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
VITE_FIREBASE_MEASUREMENT_ID=
